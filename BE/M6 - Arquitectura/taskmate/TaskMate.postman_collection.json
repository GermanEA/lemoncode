{
	"info": {
		"name": "TaskMate API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://localhost:7089",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "POST get token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/token",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "token"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"usuario@example.com\",\n  \"name\": \"Usuario Demo\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "Tasks",
			"item": [
				{
					"name": "GET all tasks",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks"]
						}
					}
				},
				{
					"name": "GET task by id",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "00000000-0000-0000-0000-000000000000"
								}
							]
						}
					}
				},
				{
					"name": "POST create task",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Mi primera tarea\",\n  \"description\": \"Descripción opcional\",\n  \"status\": 0,\n  \"dueDate\": null\n}"
						}
					}
				},
				{
					"name": "PUT update task",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "00000000-0000-0000-0000-000000000000"
								}
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Tarea actualizada\",\n  \"description\": \"Nueva descripción\",\n  \"status\": 1,\n  \"dueDate\": \"2026-12-31T00:00:00\"\n}"
						}
					}
				},
				{
					"name": "DELETE task",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "00000000-0000-0000-0000-000000000000"
								}
							]
						}
					}
				},
				{
					"name": "POST add collaborator",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id/collaborators/:userId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id", "collaborators", ":userId"],
							"variable": [
								{
									"key": "id",
									"value": "00000000-0000-0000-0000-000000000000"
								},
								{
									"key": "userId",
									"value": "00000000-0000-0000-0000-000000000000"
								}
							]
						}
					}
				}
			]
		}
	]
}
